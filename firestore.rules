rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES
     * 
     * [DEPLOYMENT TRIGGER: Applying broad authenticated access for PMS operations]
     * 
     * This recursive rule allows any authenticated user to perform read (get/list) 
     * and write operations on all documents in the database.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}