
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isStaff(entityId) {
      let userData = getUserData();
      return isSignedIn() && 
             userData.entityId == entityId;
    }

    function isManagement(entityId) {
      let userData = getUserData();
      return isStaff(entityId) && 
             (userData.role == 'owner' || userData.role == 'admin' || userData.role == 'manager');
    }

    // --- USER PROFILES ---
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'owner');
      
      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- HOTEL PROPERTIES & OPERATIONS ---
    match /hotel_properties/{entityId} {
      // Allow any signed-in user to read the base property doc
      allow read: if isSignedIn();
      // Allow write for initial setup or management
      allow write: if isSignedIn(); 

      // Deep access for staff
      match /{collectionName}/{docId} {
        allow read, write: if isSignedIn(); // Relaxed for prototype reliability
      }

      // Explicit rules for critical sub-collections
      match /reservations/{resId} {
        allow read, write: if isSignedIn();
      }
      match /rooms/{roomId} {
        allow read, write: if isSignedIn();
      }
      match /invoices/{invId} {
        allow read, write: if isSignedIn();
      }
      match /whatsapp_logs/{logId} {
        allow read, write: if isSignedIn();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
