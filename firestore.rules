rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES (PROTOTYPE MODE)
     * 
     * Philosophy:
     * In the prototype phase, we allow authenticated users to perform operations.
     * In production, this would be restricted using custom claims (entityId, role).
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // --- Collection Rules ---

    /**
     * @description Hotel Properties access.
     */
    match /hotel_properties/{hotelPropertyId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description User profiles access.
     */
    match /user_profiles/{userId} {
      allow read, write: if isSignedIn();

      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Operational data under a Hotel Property.
     */
    match /hotel_properties/{hotelPropertyId}/{collection}/{id} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Housekeeping tasks.
     */
    match /hotel_properties/{hotelPropertyId}/housekeeping_tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Laundry orders.
     */
    match /hotel_properties/{hotelPropertyId}/guest_laundry_orders/{orderId}/{subpath=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description Daily teams.
     */
    match /hotel_properties/{hotelPropertyId}/daily_teams/{teamId}/{subpath=**} {
      allow read, write: if isSignedIn();
    }

    /**
     * @description System logs.
     */
    match /hotel_properties/{hotelPropertyId}/system_activity_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}