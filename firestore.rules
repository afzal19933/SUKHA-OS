
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES
     * 
     * [DEPLOYMENT TRIGGER: Applying global authenticated access for PMS operations]
     * 
     * Broad access for authenticated users to manage all resort operations, 
     * including collection listing (housekeeping tasks, maintenance, etc.)
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
