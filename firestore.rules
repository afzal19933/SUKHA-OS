rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HOTEL INVENTORY MANAGEMENT SYSTEM - SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements an "Authorization Independence" model. Every document in the system
     * is associated with a specific hotel property via a mandatory 'entityId' field. 
     * Authorization is determined by comparing the 'entityId' in the document with the 
     * 'entityId' claim present in the user's authentication token.
     *
     * DATA STRUCTURE:
     * Data is organized into top-level collections (inventory_items, suppliers, purchase_orders, 
     * purchase_order_items, stock_transactions). All documents are "flat" at the top level 
     * but logically grouped by their denormalized 'entityId'.
     *
     * KEY SECURITY DECISIONS:
     * 1. Access is restricted to authenticated users who possess a valid 'entityId' claim.
     * 2. Multitenancy is enforced at the document level: users can only read or write 
     *    data belonging to their specific hotel property.
     * 3. Relational integrity is enforced for 'entityId' to prevent cross-tenant data 
     *    leakage or movement. Once a document is created for a hotel, it cannot be moved.
     * 4. Prototyping Mode: Schema validation is ignored for content fields to allow for 
     *    rapid UI development, while strictly enforcing entity-based access control.
     *
     * DENORMALIZATION FOR AUTHORIZATION:
     * The 'entityId' is denormalized into every single document. This allows security rules 
     * to perform high-performance checks without using `get()` lookups, ensuring 
     * scalability and reducing read costs.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Validates that the user belongs to the entity specified in the document. */
    function matchesEntity(docData) {
      return isSignedIn() && docData.entityId == request.auth.token.entityId;
    }

    /** @description Enforces that a specific field remains unchanged during an update. */
    function isImmutable(field) {
      return request.resource.data[field] == resource.data[field];
    }

    /** @description Combines authentication, existence, and entity-ownership checks for destructive actions. */
    function isExistingEntityData() {
      return isSignedIn() && resource != null && matchesEntity(resource.data);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual inventory items (linen, toiletries, etc.).
     * @path /inventory_items/{inventoryItemId}
     * @allow User with entityId "HOTEL_001" (create) a document where data.entityId is "HOTEL_001".
     * @deny User with entityId "HOTEL_001" (get) a document where data.entityId is "HOTEL_999".
     * @principle Enforces tenant-isolation via denormalized entityId.
     */
    match /inventory_items/{inventoryItemId} {
      allow get, list: if matchesEntity(resource.data);
      allow create: if matchesEntity(request.resource.data);
      allow update: if isExistingEntityData() && isImmutable('entityId');
      allow delete: if isExistingEntityData();
    }

    /**
     * @description Rules for vendors/suppliers providing hotel goods.
     * @path /suppliers/{supplierId}
     * @allow User with entityId "HOTEL_001" (list) documents filtered by entityId == "HOTEL_001".
     * @deny User with entityId "HOTEL_001" (update) a supplier to change its entityId.
     * @principle Prevents cross-hotel data exposure and maintains relational consistency.
     */
    match /suppliers/{supplierId} {
      allow get, list: if matchesEntity(resource.data);
      allow create: if matchesEntity(request.resource.data);
      allow update: if isExistingEntityData() && isImmutable('entityId');
      allow delete: if isExistingEntityData();
    }

    /**
     * @description Rules for purchase orders generated for suppliers.
     * @path /purchase_orders/{purchaseOrderId}
     * @allow User with entityId "HOTEL_001" (create) an order with status 'draft'.
     * @deny Unauthenticated user (get) any purchase order.
     * @principle Restricts financial and procurement data to authorized hotel staff.
     */
    match /purchase_orders/{purchaseOrderId} {
      allow get, list: if matchesEntity(resource.data);
      allow create: if matchesEntity(request.resource.data);
      allow update: if isExistingEntityData() && isImmutable('entityId');
      allow delete: if isExistingEntityData();
    }

    /**
     * @description Rules for specific line items within a purchase order.
     * @path /purchase_order_items/{purchaseOrderItemId}
     * @allow User with entityId "HOTEL_001" (create) a line item linked to their hotel.
     * @deny User with entityId "HOTEL_001" (delete) a line item belonging to "HOTEL_002".
     * @principle Ensures granular order details are protected by the same entity-scope as the parent.
     */
    match /purchase_order_items/{purchaseOrderItemId} {
      allow get, list: if matchesEntity(resource.data);
      allow create: if matchesEntity(request.resource.data);
      allow update: if isExistingEntityData() && isImmutable('entityId');
      allow delete: if isExistingEntityData();
    }

    /**
     * @description Rules for recording every stock movement (purchases, consumption, laundry).
     * @path /stock_transactions/{stockTransactionId}
     * @allow User (create) a transaction where performedByUserId matches their own UID and entityId matches their token.
     * @deny User (update) or (delete) a stock transaction once recorded (Audit Log Integrity).
     * @principle Ensures an immutable audit trail of stock movements for a specific hotel.
     */
    match /stock_transactions/{stockTransactionId} {
      allow get, list: if matchesEntity(resource.data);
      allow create: if matchesEntity(request.resource.data) && request.resource.data.performedByUserId == request.auth.uid;
      // Stock transactions are typically immutable audit logs; updates and deletes are restricted.
      allow update: if false; 
      allow delete: if false;
    }

  }
}