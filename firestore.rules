
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isStaff(entityId) {
      let userData = getUserData();
      return isSignedIn() && 
             userData.entityId == entityId && 
             userData.isActive == true;
    }

    function isManagement(entityId) {
      let userData = getUserData();
      return isStaff(entityId) && 
             (userData.role == 'owner' || userData.role == 'admin' || userData.role == 'manager');
    }

    // --- USER PROFILES ---
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
      
      match /notifications/{notifId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // --- HOTEL PROPERTIES & OPERATIONS ---
    match /hotel_properties/{entityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow initial property setup

      // Generic catch-all for staff collections
      match /{collectionName}/{docId} {
        allow read, write: if isStaff(entityId);
      }

      // Restrict management-only collections
      match /expenses/{expId} {
        allow read, write: if isManagement(entityId);
      }
      
      match /whatsapp_templates/{templateId} {
        allow read: if isStaff(entityId);
        allow write: if isManagement(entityId);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
