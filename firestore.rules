rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - UNIFIED SECURITY RULES
     * Enforces role-based access control and multi-tenancy.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description User Profiles
     * Users can read/write their own profile.
     */
    match /user_profiles/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // Allow admins to see team members for the same entity
      allow list: if isSignedIn();
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     * Data is isolated by entityId.
     */
    match /hotel_properties/{entityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Restrict to admin roles in production

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    /**
     * @description Legacy/Schema Compatibility
     * Matches paths defined in backend.json IR.
     */
    match /inventory_items/{id} { allow read, write: if isSignedIn(); }
    match /suppliers/{id} { allow read, write: if isSignedIn(); }
    match /purchase_orders/{id} { allow read, write: if isSignedIn(); }
    match /purchase_order_items/{id} { allow read, write: if isSignedIn(); }
    match /stock_transactions/{id} { allow read, write: if isSignedIn(); }

  }
}