rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - ROLE-BASED ACCESS CONTROL
     * Admin: Global Master (Read/Write all)
     * Owner: Entity-Specific (Read-Only)
     * Staff/Manager: Entity-Specific (Scoped)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to get user profile data
    function getUserProfile() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    // Check if user is the master administrator
    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@sukha.os' ||
        getUserProfile().role == 'admin'
      );
    }

    // Check if user is an owner of a specific entity
    function isOwner(entityId) {
      return isSignedIn() && getUserProfile().role == 'owner' && getUserProfile().entityId == entityId;
    }

    /** 
     * @description User Profiles
     * Users can read their own profiles. Admins can manage all.
     */
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     */
    match /hotel_properties/{entityId} {
      // Metadata (name, etc) is readable by all staff to support the switcher.
      // Sensitive data is protected in subcollections.
      allow read: if isSignedIn();
      // Only Master Admin can modify property settings.
      allow write: if isMasterAdmin();

      match /{allSubcollections=**} {
        // Reads allowed for Master Admin or people assigned to this entity.
        allow read: if isMasterAdmin() || 
                     isOwner(entityId) || 
                     (isSignedIn() && getUserProfile().entityId == entityId);
        
        // Writes reserved for Master Admin and non-owner staff assigned to the entity.
        allow write: if isMasterAdmin() || 
                      (isSignedIn() && getUserProfile().role != 'owner' && getUserProfile().entityId == entityId);
      }
    }

    /**
     * @description Global Configs
     */
    match /laundry_items/{id} { allow read: if isSignedIn(); allow write: if isMasterAdmin(); }
    match /inventory_stocks/{id} { allow read: if isSignedIn(); allow write: if isMasterAdmin(); }

  }
}