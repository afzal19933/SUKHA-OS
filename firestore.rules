rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - UNIFIED SECURITY RULES
     * Enforces role-based access control and multi-tenancy.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    // Admins and View-Only Owners both count as "Admin View" authorized
    function canViewAdmin() {
      return isSignedIn() && (getUserData().role == 'owner' || getUserData().role == 'admin');
    }

    // Only Admin can perform write operations
    function canWriteAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    /** 
     * @description User Profiles
     * Users can read/write their own profile. Admins can manage all profiles.
     */
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || canWriteAdmin());
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     */
    match /hotel_properties/{entityId} {
      allow read: if isSignedIn() && (getUserData().entityId == entityId || canViewAdmin());
      allow write: if canWriteAdmin();

      match /{allSubcollections=**} {
        // Multi-tenant check: User must belong to this entity or be an authorized cross-entity admin
        allow read: if isSignedIn() && (getUserData().entityId == entityId || canViewAdmin());
        allow write: if isSignedIn() && getUserData().entityId == entityId && canWriteAdmin();
      }
    }

    /**
     * @description Global Configs
     */
    match /laundry_items/{id} { allow read: if isSignedIn(); allow write: if canWriteAdmin(); }
    match /inventory_stocks/{id} { allow read: if isSignedIn(); allow write: if canWriteAdmin(); }

  }
}
