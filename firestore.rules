rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - GLOBAL AUTHENTICATED ACCESS
     * 
     * [DEPLOYMENT TRIGGER: Force re-sync of security policy - v1.0.4]
     * 
     * This recursive rule allows any authenticated user to perform read (get/list) 
     * and write operations on all documents and sub-collections in the database.
     * 
     * This specifically resolves "Missing or insufficient permissions" errors
     * when performing 'list' operations on property sub-collections.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Explicitly target property sub-collections to ensure 'list' operations are authorized
    match /hotel_properties/{propertyId}/{subcollection=**} {
      allow read, write: if request.auth != null;
    }
  }
}