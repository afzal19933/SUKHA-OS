rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - ULTIMATE AUTHENTICATED ACCESS
     * 
     * [DEPLOYMENT TRIGGER: Force re-sync of security policy - v1.0.6]
     * 
     * This rule provides the highest level of access for authenticated users.
     * It uses a recursive wildcard to match ALL documents at any depth.
     * This specifically grants 'list' and 'get' permissions across all
     * property sub-collections including housekeeping_tasks, reservations, and invoices.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}