rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - UNIFIED SECURITY RULES
     * Enforces role-based access control and multi-tenancy.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (getUserData().role == 'owner' || getUserData().role == 'admin');
    }

    /** 
     * @description User Profiles
     * Users can read/write their own profile. Admins can manage all profiles.
     */
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     */
    match /hotel_properties/{entityId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn();
      }
    }

    /**
     * @description Global Configs
     */
    match /laundry_items/{id} { allow read, write: if isSignedIn(); }
    match /inventory_stocks/{id} { allow read, write: if isSignedIn(); }

  }
}