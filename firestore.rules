rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - ROLE-BASED ACCESS CONTROL
     * Admin: Global Master (Read/Write all)
     * Owner: Entity-Specific (Read-Only)
     * Staff/Manager: Entity-Specific (Scoped Read/Write)
     * Global Access: Profiles assigned to 'all' can access any entityId
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserProfile() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'admin@sukha.os' ||
        getUserProfile().role == 'admin'
      );
    }

    function isAssignedToEntity(entityId) {
      let profile = getUserProfile();
      return isSignedIn() && (
        isMasterAdmin() || 
        profile.entityId == entityId ||
        profile.entityId == 'all'
      );
    }

    /** 
     * @description User Profiles
     * Admins can manage all. Users can read their own.
     */
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     */
    match /hotel_properties/{entityId} {
      // Metadata readable for property switcher
      allow read: if isSignedIn();
      // Only Admin can modify property settings
      allow write: if isMasterAdmin();

      match /{allSubcollections=**} {
        // Reads: Admin (Any), Owner (Assigned/All), Staff (Assigned/All)
        allow read: if isAssignedToEntity(entityId);
        
        // Writes: Admin (Any), Staff/Manager (Assigned/All), Owner (NEVER)
        allow write: if isMasterAdmin() || (
          isAssignedToEntity(entityId) && 
          getUserProfile().role != 'owner'
        );
      }
    }

    match /laundry_items/{id} { allow read: if isSignedIn(); allow write: if isMasterAdmin(); }
    match /inventory_stocks/{id} { allow read: if isSignedIn(); allow write: if isMasterAdmin(); }
  }
}