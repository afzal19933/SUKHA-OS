rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES (PROTOTYPE MODE)
     * 
     * In the prototype phase, we allow any authenticated user to perform operations.
     * This prevents permission blockers when listing collections or accessing sub-collections.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    match /{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}