rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES (AUTHENTICATED PROTOTYPE)
     * 
     * In this prototype phase, we allow any authenticated staff member 
     * to perform any operation on the database. This ensures maximum 
     * flexibility for resort operations and avoids permission bottlenecks.
     */

    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}