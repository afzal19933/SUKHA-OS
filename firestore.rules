rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS - ROLE-BASED ACCESS CONTROL
     * Admin: Global Master (Read/Write all)
     * Owner: Entity-Specific (Read-Only)
     * Staff/Manager: Entity-Specific (Scoped)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }

    function isOwner(entityId) {
      return isSignedIn() && getUserData().role == 'owner' && getUserData().entityId == entityId;
    }

    /** 
     * @description User Profiles
     * Admin can manage all. Users can read their own.
     */
    match /user_profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      
      match /notifications/{notificationId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    /**
     * @description Hotel Properties & Multi-tenancy
     */
    match /hotel_properties/{entityId} {
      // Admin sees all. Owner sees their entity only.
      allow read: if isAdmin() || isOwner(entityId);
      // Only Admin can modify property settings or root docs.
      allow write: if isAdmin();

      match /{allSubcollections=**} {
        // Reads allowed for Admin and specific Owner
        allow read: if isAdmin() || isOwner(entityId) || (isSignedIn() && getUserData().entityId == entityId);
        // Writes strictly reserved for Admin (and Staff/Manager based on app logic, but Admin is master)
        allow write: if isAdmin() || (isSignedIn() && getUserData().role != 'owner' && getUserData().entityId == entityId);
      }
    }

    /**
     * @description Global Configs
     */
    match /laundry_items/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /inventory_stocks/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }

  }
}