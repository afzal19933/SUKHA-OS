
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SUKHA OS SECURITY RULES
     * 
     * [DEPLOYMENT TRIGGER: Re-provisioning paths for maintenance/housekeeping tasks]
     * 
     * Broad access for authenticated users to manage all resort operations.
     */

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
