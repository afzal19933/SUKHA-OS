
{
  "entities": {
    "HotelProperty": {
      "title": "HotelProperty",
      "type": "object",
      "description": "Represents a single hotel property managed by SUKHA OS.",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "name", "isActive", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific information and roles.",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "name", "email", "role", "isActive", "createdAt", "updatedAt"]
    },
    "Room": {
      "title": "Room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "floor": { "type": "number" },
        "building": { "type": "string", "enum": ["Old Apartment", "New Apartment"] },
        "roomTypeId": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "roomNumber", "status"]
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "guestName": { "type": "string" },
        "roomNumber": { "type": "string" },
        "building": { "type": "string" },
        "stayType": { "type": "string", "enum": ["Daily", "Monthly", "Yearly"] },
        "checkInDate": { "type": "string", "format": "date" },
        "checkOutDate": { "type": "string", "format": "date" },
        "status": { "type": "string" }
      }
    },
    "LaundryItem": {
      "title": "LaundryItem",
      "type": "object",
      "description": "Master list of laundry services and items.",
      "properties": {
        "itemName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["guest", "linen"] },
        "hotelRate": { "type": "number", "description": "Rate charged to guests" },
        "vendorRate": { "type": "number", "description": "Rate charged by Signature Laundry" },
        "unit": { "type": "string" }
      }
    },
    "LaundryOrder": {
      "title": "LaundryOrder",
      "type": "object",
      "description": "Individual laundry orders for guests or linen batches.",
      "properties": {
        "roomId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "guestName": { "type": "string" },
        "reservationId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["sent", "returned", "paid"] },
        "hotelTotal": { "type": "number" },
        "vendorTotal": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    },
    "MaintenanceSchedule": {
      "title": "MaintenanceSchedule",
      "type": "object",
      "description": "Recurring maintenance tasks for property assets.",
      "properties": {
        "id": { "type": "string" },
        "itemName": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly", "yearly"] },
        "nextDue": { "type": "string", "format": "date" },
        "lastDone": { "type": "string", "format": "date" },
        "notes": { "type": "string" }
      },
      "required": ["id", "itemName", "frequency", "nextDue"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/hotel_properties/{hotelPropertyId}": {
      "schema": { "$ref": "#/backend/entities/HotelProperty" },
      "description": "Top-level hotel property documents."
    },
    "/hotel_properties/{hotelPropertyId}/laundry_items/{itemId}": {
      "schema": { "$ref": "#/backend/entities/LaundryItem" },
      "description": "Master laundry items and rates."
    },
    "/hotel_properties/{hotelPropertyId}/guest_laundry_orders/{orderId}": {
      "schema": { "$ref": "#/backend/entities/LaundryOrder" },
      "description": "Guest specific laundry orders."
    },
    "/hotel_properties/{hotelPropertyId}/linen_laundry_batches/{batchId}": {
      "schema": { "type": "object" },
      "description": "Batches of hotel linen sent for cleaning."
    },
    "/hotel_properties/{hotelPropertyId}/maintenance_schedules/{scheduleId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceSchedule" },
      "description": "Routine maintenance schedules for assets."
    },
    "/hotel_properties/{hotelPropertyId}/reservations/{resId}": {
      "schema": { "$ref": "#/backend/entities/Reservation" },
      "description": "Guest reservations."
    }
  }
}
