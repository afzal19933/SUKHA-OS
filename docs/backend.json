
{
  "entities": {
    "HotelProperty": {
      "title": "HotelProperty",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "isActive": { "type": "boolean" },
        "gstin": { "type": "string" },
        "whatsappNumber": { "type": "string", "description": "The official business number used to send messages." },
        "whatsappBusinessId": { "type": "string" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "manager", "supervisor", "staff"] },
        "isActive": { "type": "boolean" },
        "permissions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "guestName": { "type": "string" },
        "roomNumber": { "type": "string" },
        "status": { "type": "string", "enum": ["confirmed", "checked_in", "checked_out", "cancelled"] },
        "checkInDate": { "type": "string", "format": "date" },
        "checkOutDate": { "type": "string", "format": "date" },
        "bookingSource": { "type": "string" },
        "negotiatedRate": { "type": "number" },
        "phoneNumber": { "type": "string", "description": "WhatsApp enabled phone number" }
      }
    },
    "WhatsAppMessageLog": {
      "title": "WhatsAppMessageLog",
      "type": "object",
      "description": "Logs all WhatsApp communication including AI interactions.",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string" },
        "direction": { "type": "string", "enum": ["incoming", "outgoing"] },
        "message": { "type": "string" },
        "response": { "type": "string" },
        "status": { "type": "string" },
        "isAiQuery": { "type": "boolean" },
        "intent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WhatsAppTemplate": {
      "title": "WhatsAppTemplate",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "body": { "type": "string" },
        "triggerEvent": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "SystemAlert": {
      "title": "SystemAlert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "alertType": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": {
      "/user_profiles/{userId}": {
        "schema": "UserProfile",
        "description": "Stores core user profile and role data."
      },
      "/hotel_properties/{entityId}": {
        "schema": "HotelProperty",
        "description": "Root document for a specific hotel/apartment entity."
      },
      "/hotel_properties/{entityId}/reservations/{resId}": {
        "schema": "Reservation",
        "description": "Guest stay records."
      },
      "/hotel_properties/{entityId}/whatsapp_logs/{logId}": {
        "schema": "WhatsAppMessageLog",
        "description": "Log of all automated and AI WhatsApp messages."
      },
      "/hotel_properties/{entityId}/whatsapp_templates/{templateId}": {
        "schema": "WhatsAppTemplate",
        "description": "Pre-defined messages for guest automation."
      },
      "/hotel_properties/{entityId}/system_alerts/{alertId}": {
        "schema": "SystemAlert",
        "description": "Critical operational alerts sent via WhatsApp."
      }
    }
  }
}
