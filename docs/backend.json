
{
  "entities": {
    "HotelProperty": {
      "title": "HotelProperty",
      "type": "object",
      "description": "Represents a single hotel property managed by SUKHA OS.",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "gstin": { "type": "string" },
        "pan": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "name", "isActive", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Stores user-specific information and roles.",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "isActive": { "type": "boolean" },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "name", "email", "role", "isActive", "createdAt", "updatedAt"]
    },
    "Room": {
      "title": "Room",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "roomNumber": { "type": "string" },
        "floor": { "type": "number" },
        "roomTypeId": { "type": "string" },
        "status": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "roomNumber", "status"]
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "guestName": { "type": "string" },
        "roomNumber": { "type": "string" },
        "status": { "type": "string" },
        "checkInDate": { "type": "string", "format": "date-time" },
        "checkOutDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "guestName", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "reservationId": { "type": "string" },
        "guestName": { "type": "string" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "invoiceNumber", "totalAmount", "status", "createdAt"]
    },
    "HousekeepingTask": {
      "title": "HousekeepingTask",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "entityId": { "type": "string" },
        "roomId": { "type": "string" },
        "taskType": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "entityId", "roomId", "taskType", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/hotel_properties/{hotelPropertyId}": {
      "schema": { "$ref": "#/backend/entities/HotelProperty" },
      "description": "Top-level hotel property documents."
    },
    "/user_profiles/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Global user profiles."
    },
    "/hotel_properties/{hotelPropertyId}/rooms/{roomId}": {
      "schema": { "$ref": "#/backend/entities/Room" },
      "description": "Rooms within a property."
    },
    "/hotel_properties/{hotelPropertyId}/reservations/{resId}": {
      "schema": { "$ref": "#/backend/entities/Reservation" },
      "description": "Property reservations."
    },
    "/hotel_properties/{hotelPropertyId}/invoices/{invoiceId}": {
      "schema": { "$ref": "#/backend/entities/Invoice" },
      "description": "Property invoices."
    },
    "/hotel_properties/{hotelPropertyId}/housekeeping_tasks/{taskId}": {
      "schema": { "$ref": "#/backend/entities/HousekeepingTask" },
      "description": "Tasks for housekeeping and maintenance."
    },
    "/user_profiles/{userId}/notifications/{notificationId}": {
      "schema": { "type": "object" },
      "description": "User specific notifications."
    }
  }
}
