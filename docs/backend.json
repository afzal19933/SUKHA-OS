{
  "entities": {
    "InventoryStock": {
      "title": "InventoryStock",
      "description": "Tracks current quantities of consumables and assets.",
      "type": "object",
      "properties": {
        "itemName": { "type": "string" },
        "category": { "type": "string" },
        "currentStock": { "type": "number" },
        "unit": { "type": "string" },
        "minStock": { "type": "number" },
        "lastRestockDate": { "type": "string", "format": "date-time" }
      }
    },
    "InventoryTransaction": {
      "title": "InventoryTransaction",
      "description": "Logs every stock movement (purchase or consumption).",
      "type": "object",
      "properties": {
        "itemId": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "consumption"] },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "performedBy": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/hotel_properties/{entityId}/inventory_stocks/{stockId}",
        "definition": {
          "entityName": "inventoryStock",
          "schema": { "$ref": "#/backend/entities/InventoryStock" },
          "description": "Real-time stock levels for the property."
        }
      },
      {
        "path": "/hotel_properties/{entityId}/inventory_transactions/{txnId}",
        "definition": {
          "entityName": "inventoryTransaction",
          "schema": { "$ref": "#/backend/entities/InventoryTransaction" },
          "description": "Audit log of all stock changes."
        }
      }
    ]
  }
}